# Optional: use xurl CLI auth instead of bearer token. Preferred for posting/searching through your account.
XURL_APP=

# Optional: direct bearer token for recent-search API reads only. Do not commit real tokens.
X_BEARER_TOKEN=

# Funnel tuning
AI_ALPHA_SCAN_LIMIT=25
AI_ALPHA_MIN_SCORE=60
AI_ALPHA_OUTPUT_DIR=.data/runs

# Optional source seed list, comma-separated X handles without @
AI_ALPHA_SEED_HANDLES=sama,karpathy,OpenAI,AnthropicAI,GoogleDeepMind,MetaAI,perplexity_ai,huggingface,cursor_ai,swyx

# Optional broad search queries separated by ||. Use this for search-page style discovery outside curated handles.
AI_ALPHA_EXTRA_BROAD_QUERIES=

# Optional Telegram digest delivery. Keep real tokens in .env.local only.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_SCORE=70
TELEGRAM_MAX_ITEMS=5
